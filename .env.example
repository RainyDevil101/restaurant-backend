PORT=3000
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d
# Local dev uses the Docker Postgres (docker compose up -d). SSL is auto-off for localhost.
# Production (Render) overrides this with its own DATABASE_URL in the dashboard.
DATABASE_URL=postgres://subito:subito@localhost:5432/subito
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

BACKUP_CRON=0 12 * * *
BACKUP_TIMEZONE=America/Santiago
BACKUP_RETENTION_DAYS=14

# BACKUP_DRIVER: local | s3
BACKUP_DRIVER=s3

# S3-compatible storage (Backblaze B2, Cloudflare R2, AWS S3) — required when BACKUP_DRIVER=s3
S3_ENDPOINT=https://s3.us-east-005.backblazeb2.com
S3_REGION=us-east-005
S3_BUCKET=subito-backups
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PREFIX=
