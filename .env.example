# Backend (NestJS) — copy to .env for local development.
#
# IN PRODUCTION do NOT ship a .env file: set every value in your host's
# dashboard (Render → Service → Environment). Never commit real secrets.
# Joi validates these at startup (src/config/env.validation.ts) — missing or
# invalid vars crash fast.

# HTTP port. Locally any free port; on Render leave this UNSET — Render injects
# PORT automatically and the app binds to it.
PORT=3000

# Allowed frontend origin(s), comma-separated. Only listed origins get CORS.
# This also gates the WebSocket gateway (corsOrigins()), so REST + realtime
# are covered together.
#   Dev:  http://localhost:5173
#   Prod: https://<your-frontend-host>   (HTTPS, exact origin, no localhost)
CORS_ORIGIN=http://localhost:5173

# JWT signing secret, min 16 chars. Use a long random value and a DIFFERENT one
# per environment. Generate with:  openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Postgres connection string.
#   Dev:  Docker Postgres (docker compose up -d); SSL auto-off for localhost.
#   Prod: the Render Postgres URL (use the INTERNAL URL when the DB is on Render
#         too — faster, no public egress); SSL auto-on for remote hosts.
DATABASE_URL=postgres://subito:subito@localhost:5432/subito

# Rate limiting (global). Stricter per-route limits apply to POST /auth/login.
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Daily off-server DB backup (RNF05).
BACKUP_CRON=0 12 * * *
BACKUP_TIMEZONE=America/Santiago
BACKUP_RETENTION_DAYS=14

# BACKUP_DRIVER: local (dev only — Render disk is ephemeral) | s3 (production)
BACKUP_DRIVER=s3

# S3-compatible storage (Backblaze B2, Cloudflare R2, AWS S3) — required when
# BACKUP_DRIVER=s3. On B2 keep Object Lock DISABLED or retention pruning fails.
S3_ENDPOINT=https://s3.us-east-005.backblazeb2.com
S3_REGION=us-east-005
S3_BUCKET=subito-backups
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PREFIX=
